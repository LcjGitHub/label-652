COMPOSE_PROJECT_NAME=product-management

NODE_ENV=production

BACKEND_HOST=0.0.0.0
BACKEND_PORT=3005

FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5185

VITE_API_BASE_URL=/api

JWT_SECRET=your-secret-key-change-in-production-please-change-this
JWT_EXPIRES_IN=7d

CORS_ORIGIN=*

DB_TYPE=sqlite
DB_SQLITE_PATH=/app/data/products.db

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_NAME=product_management

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=product_management

USE_REDIS=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

NGINX_PORT=80

BACKEND_REPLICAS=1
